{
  "config_path": "/usr/data/guppyscreen/guppyconfig.json",
  "default_printer": "k1",
  "display_rotate": 0,
  "display_sleep_sec": -1,
  "guppy_init_script": "/etc/init.d/S99guppyscreen",
  "invert_z_icon": null,
  "log_path": "/usr/data/printer_data/logs/guppyscreen.log",
  "printers": {
    "k1": {
      "default_macros": {
        "cooldown": "SET_HEATER_TEMPERATURE HEATER=extruder TARGET=0\nSET_HEATER_TEMPERATURE HEATER=heater_bed TARGET=0",
        "load_filament": "LOAD_FILAMENT",
        "unload_filament": "UNLOAD_FILAMENT"
      },
      "fans": [
        {
          "display_name": "Toolhead Fan",
          "id": "output_pin fan0"
        },
        {
          "display_name": "Back Fan",
          "id": "output_pin fan1"
        }
      ],
      "leds": [
        {
          "display_name": "Light",
          "id": "output_pin light_pin"
        }
      ],
